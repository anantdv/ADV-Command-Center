# Backend-only ERPNext/Frappe connection settings.
ERP_SERVER_URL=https://erp.anantdv.com
BACKEND_PORT=3001
NODE_ENV=development

# Frontend integration configuration.
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false
VITE_ERP_SITE_URL=https://erp.anantdv.com
VITE_APP_NAME=ADV Command Center

# Development-only Vite proxy target when VITE_API_BASE_URL uses /api.
VITE_FASTAPI_PROXY_TARGET=http://127.0.0.1:8000
