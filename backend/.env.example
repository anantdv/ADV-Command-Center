APP_NAME="ADV Command Center"
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

DATABASE_URL=sqlite:///./erp_ai_command_center.db

USE_MOCK_DATA=false

FRAPPE_BASE_URL=http://your-erpnext-site.local
FRAPPE_AUTH_MODE=token
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
FRAPPE_FORWARD_SESSION_COOKIE=true
FRAPPE_SESSION_COOKIE_NAME=sid

ENABLE_AI_RUNTIME=false
ENABLE_EXTERNAL_MODEL=false

LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.1

SECRET_KEY=change-me

FILE_STORAGE_BACKEND=local
FILE_STORAGE_ROOT=./generated_files
FILE_DOWNLOAD_BASE_URL=http://localhost:8000/api/library/files
MAX_EXPORT_ROWS=5000
PDF_RENDERER=reportlab
ENABLE_FILE_GENERATION=true
AGGREGATION_MAX_SOURCE_ROWS=5000
ENABLE_ERP_WORKFLOW_INBOX=true
WORKFLOW_APPROVAL_LIMIT=50
WORKFLOW_APPROVAL_DOCTYPES=Quotation,Sales Order,Purchase Order,Sales Invoice,Purchase Invoice,Delivery Note,Purchase Receipt,Material Request,Payment Entry,Journal Entry,Expense Claim,Leave Application,Issue
ENABLE_ANALYTICS=true
ANALYTICS_MAX_SOURCE_ROWS=5000
ANALYTICS_DEFAULT_LIMIT=20
ANALYTICS_ALLOW_RAW_DETAIL_EXPORT=false
ENABLE_REPORT_COMPOSER=true
REPORT_COMPOSER_MAX_SOURCE_ROWS=5000
REPORT_COMPOSER_DEFAULT_LIMIT=100
REPORT_COMPOSER_MAX_GROUPS=100
REPORT_COMPOSER_ALLOW_DETAIL_ROWS=true
REPORT_COMPOSER_ALLOW_MULTI_SOURCE=false
REPORT_COMPOSER_SAVE_VIEWS=true
ENABLE_DYNAMIC_SUGGESTIONS=true
MAX_DYNAMIC_SUGGESTIONS=6
ENABLE_SUGGESTION_EXECUTE_ENDPOINT=true

# Vertex Gemini is used only for intent extraction. ERPNext rows are never sent.
ENABLE_LLM_EXTRACTION=false
LLM_PROVIDER=disabled
LLM_MODE=intent_only
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
LLM_ALLOW_EXTERNAL=false
LLM_ALLOW_ERP_DATA=false
LLM_ALLOW_MASTER_DATA=false
LLM_ALLOW_TRANSACTION_DATA=false
LLM_ALLOW_REPORT_ROWS=false
LLM_REDACTION_ENABLED=true
LLM_FAIL_CLOSED=true
LLM_LOG_PROMPTS=false
LLM_LOG_RESPONSES=false
LLM_LOG_REDACTED_PROMPTS=false
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1200
LLM_TEMPERATURE=0.0
LLM_CONFIDENCE_THRESHOLD=0.65
EXTRACTION_FALLBACK_TO_RULES=true
ALLOW_UNSAFE_LLM_CONFIG=false

ENABLE_KNOWLEDGE_BASE=true
ENABLE_RAG=true
KNOWLEDGE_STORAGE_ROOT=./knowledge_files
KNOWLEDGE_VECTOR_BACKEND=numpy
KNOWLEDGE_CHUNK_SIZE=900
KNOWLEDGE_CHUNK_OVERLAP=150
KNOWLEDGE_TOP_K=5
KNOWLEDGE_MAX_FILE_BYTES=20971520
EMBEDDING_PROVIDER=vertex
VERTEX_EMBEDDING_MODEL=text-embedding-005
RAG_LLM_PROVIDER=vertex_gemini
RAG_GEMINI_MODEL=gemini-2.5-flash
RAG_MAX_CONTEXT_CHUNKS=5
RAG_REQUIRE_CITATIONS=true
RAG_ALLOW_ERP_DATA=false
RAG_ALLOW_TRANSACTION_DATA=false
RAG_ALLOW_MASTER_DATA=false
RAG_FAIL_CLOSED=true

ENABLE_OCR=true
ENABLE_OCR_LLM_EXTRACTION=false
OCR_MAX_FILE_SIZE_MB=10
OCR_MAX_PAGES=10
OCR_LANGUAGE=eng
DOCUMENT_INTAKE_STORAGE_ROOT=./document_intake_files
